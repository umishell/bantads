# --- Node.js (gateway, scripts, etc.) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Gradle / Kotlin / JVM (microsserviços) ---
.gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/
!gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.jar
.kotlin/

# --- Dados locais (PostgreSQL/Mongo em bind mount via Docker; nunca versionar) ---
data/

# --- Docs (local, raiz do repositório) ---
/docs/

# --- Prompts (local, raiz do repositório) ---
#/prompts/

# --- Ambiente e segredos ---
.env
.env.*
!.env.example

# --- Logs e temporários ---
*.log
*.tmp
*.swp
*~

# --- IDEs (subprojetos podem ter .gitignore próprio, ex.: frontend) ---
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# --- SO ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Testes / cobertura ---
coverage/
.nyc_output/

# Bytecode Python (scripts/integration)
scripts/integration/**/__pycache__/
scripts/integration/**/*.pyc

# Relatórios gerados localmente (integração Python em scripts/integration)
testReports/**
!testReports/README.md
!testReports/logs/README.md
!testReports/logs/.gitkeep
!testReports/logs/junit/.gitkeep
!testReports/logs/pytest/.gitkeep
!testReports/logs/docker/README.md
!testReports/logs/docker/.gitkeep
!testReports/issues/.gitkeep
!testReports/working/.gitkeep

# --- GitNexus / agentes (gerados localmente; regeneram com `gitnexus analyze`) ---
AGENTS.md
CLAUDE.md
.claude/
.gitnexus/
