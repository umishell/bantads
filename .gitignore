# --- Node.js (gateway, scripts, etc.) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Gradle / Kotlin / JVM (microsserviços) ---
.gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/
!gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.jar
.kotlin/

# --- Dados locais (PostgreSQL/Mongo em bind mount via Docker; nunca versionar) ---
data/

# --- Docs (local, raiz do repositório) ---
/docs/

# --- Ambiente e segredos ---
.env
.env.*
!.env.example

# --- Logs e temporários ---
*.log
*.tmp
*.swp
*~

# --- IDEs (subprojetos podem ter .gitignore próprio, ex.: frontend) ---
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# --- SO ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Testes / cobertura ---
coverage/
.nyc_output/
