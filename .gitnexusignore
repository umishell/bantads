# GitNexus — exclusões no estilo .gitignore (referência genérica + este repositório).
# Objetivo: menos RAM, grafo focado em código-fonte e configs — não binários, vendored deps, nem docs locais.

# =============================================================================
# Documentação & material local (este projeto)
# =============================================================================
/docs/
/tutor/

# =============================================================================
# Build, dependências vendidas & artefatos compilados
# =============================================================================
**/node_modules/
dist/
**/build/
target/
out/
**/.gradle/
.m2/
**/.kotlin/

# =============================================================================
# Ambientes, segredos & interpretadores (Python / virtualenv)
# =============================================================================
.env
.env.*
venv/
.venv/
# Cuidado: ignore qualquer pasta chamada "env/". Remova esta linha se o repo tiver código em env/.
env/

# =============================================================================
# Dados locais, cobertura & caches de teste
# =============================================================================
data/
coverage/
.nyc_output/

# =============================================================================
# Repositório Git, índice GitNexus & IDEs / editor
# =============================================================================
.git/
.gitnexus/
.cursor/
.vscode/
.cursorrules/
.idea/
*.iml

# Se a pasta agents for só logs/outputs, descomente:
# agents/**/logs/
# agents/**/cache/

# =============================================================================
# Binários, bibliotecas nativas & mídia (AST / grafo pouco úteis)
# =============================================================================
*.exe
*.dll
*.so
*.png
*.jpg
*.jpeg
*.svg
*.pdf
*.zip
*.tar.gz

# =============================================================================
# Logs, temporários & lixo de SO
# =============================================================================
logs/
*.log
*.tmp
.DS_Store
Thumbs.db
